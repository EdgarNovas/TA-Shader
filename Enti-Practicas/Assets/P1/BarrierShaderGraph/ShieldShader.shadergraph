{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "6ef5dcd72e31431da960319b76943a7a",
    "m_Group": {
        "m_Id": "e1b230baf11642f88cfd630efb2fc60c"
    },
    "m_Name": "HexGrid (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -973.0,
            "y": -860.0000610351563,
            "width": 201.00006103515626,
            "height": 94.00006103515625
        }
    },
    "m_Slots": [
        {
            "m_Id": "b36429f1d866478f958e5b86132a889f"
        },
        {
            "m_Id": "0a3049bf9469418eb944f9148da36665"
        },
        {
            "m_Id": "c20f88ee1754447882d10ad97874cca3"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "HexGrid",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 s = float2(1.0, 1.7320508);\r\nfloat4 h = float4(UV, UV - s * 0.5);\r\nfloat4 h1 = floor(h / s.xyxy) + 0.5;\r\nfloat4 h2 = h - h1 * s.xyxy;\r\n\r\nfloat dot1 = dot(h2.xy, h2.xy);\r\nfloat dot2 = dot(h2.zw, h2.zw);\r\n\r\nfloat2 res = dot1 < dot2 ? h2.xy : h2.zw;\r\nfloat2 absRes = abs(res);\r\n\r\n// Distancia desde el centro al borde\r\nfloat dist = max(dot(absRes, s * 0.5), absRes.x); \r\n\r\n// Ajustamos el grosor para que parezca una red\r\nHexEdge = smoothstep(0.5 - BlurAmount, 0.5, dist);"
}

